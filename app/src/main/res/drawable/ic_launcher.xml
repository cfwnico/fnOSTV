<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark rounded background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#151A21" />
            <corners android:radius="32dp" />
        </shape>
    </item>
    <!-- Blue circle -->
    <item android:top="18dp" android:bottom="18dp" android:left="18dp" android:right="18dp">
        <shape android:shape="oval">
            <solid android:color="#2F86F6" />
        </shape>
    </item>
    <!-- Inner dark circle (ring effect) -->
    <item android:top="38dp" android:bottom="38dp" android:left="38dp" android:right="38dp">
        <shape android:shape="oval">
            <solid android:color="#151A21" />
        </shape>
    </item>
</layer-list>
